# Server
# NODE_ENV=production  # Set automatically by Railway; set to 'production' locally to test CORS behaviour
DATABASE_URL=postgresql://user:pass@host:5432/baawa_mehram  # PostgreSQL connection string (must include pgvector extension)
RESEND_API_KEY=re_...                                        # Resend API key for sending emails
ANTHROPIC_API_KEY=sk-ant-...                                 # Anthropic API key for Claude (used in AI scoring/generation)
OPENAI_API_KEY=sk-...                                        # OpenAI API key for embeddings (pgvector knowledge base)
FOUNDER_API_KEY=your-secret-key-here                         # Secret password to access the /dashboard route
PORT=3001                                                    # Port the Express server listens on
CLAUDE_MODEL=claude-haiku-4-5-20251001                       # Claude model ID used for assessment scoring
CLIENT_URL=https://your-vercel-app.vercel.app                # Frontend URL — used for CORS (required in production)
EMAIL_FROM=assessment@yourdomain.com                         # "From" address on all outbound emails
FOUNDER_EMAIL=you@yourdomain.com                             # Founder's email — receives lead notification emails
DASHBOARD_URL=https://your-vercel-app.vercel.app             # Frontend URL used in email links to the dashboard

# Client (Vite — must be prefixed VITE_)
VITE_API_URL=http://localhost:3001                           # Base URL of the backend API, used by the React client
